generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model detail_transaksi {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  transaksi_id String    @db.Uuid
  produk_id    String    @db.Uuid
  jumlah       Int
  harga_satuan Int
  subtotal     Int
  produk       produk    @relation(fields: [produk_id], references: [id], onUpdate: NoAction)
  transaksi    transaksi @relation(fields: [transaksi_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model kategori {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nama_kategori String    @unique @db.VarChar
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  produk        produk[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model produk {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nama_produk      String             @db.VarChar
  harga            Int
  gambar_url       String?
  kategori_id      String?            @db.Uuid
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  detail_transaksi detail_transaksi[]
  kategori         kategori?          @relation(fields: [kategori_id], references: [id], onUpdate: NoAction)
  stok_detail      stok?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stok {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  produk_id   String    @unique @db.Uuid
  jumlah_stok Int       @default(0)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  produk      produk    @relation(fields: [produk_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaksi {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kode_transaksi    String             @unique @db.VarChar
  tanggal           DateTime?          @default(now()) @db.Timestamptz(6)
  total             Int
  metode_pembayaran String?            @db.VarChar
  user_id           String             @db.Uuid
  created_at        DateTime?          @default(now()) @db.Timestamptz(6)
  detail_transaksi  detail_transaksi[]
  user              users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nama       String      @db.VarChar
  email      String      @unique @db.VarChar
  password   String
  role       String      @db.VarChar
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  transaksi  transaksi[]
}
